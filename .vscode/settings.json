{
  "workbench.colorTheme": "Light Modern",
  "workbench.colorCustomizations": {
    "activityBar.background": "#E8E8E8",
    "activityBar.foreground": "#3A3A3A",
    "activityBar.activeBorder": "#AFAFAF",
    "activityBarBadge.background": "#D8AF2F",
    "activityBarBadge.foreground": "#1E1E1E",
    "sideBar.background": "#ECECEC",
    "sideBar.foreground": "#3C3C3C",
    "sideBarSectionHeader.background": "#E1E1E1",
    "editor.background": "#F3F3F3",
    "editor.foreground": "#252525",
    "editorLineNumber.foreground": "#7D7D7D",
    "editorLineNumber.activeForeground": "#4A4A4A",
    "statusBar.background": "#256B29",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.noFolderBackground": "#256B29",
    "statusBar.debuggingBackground": "#1C5A24",
    "statusBarItem.prominentBackground": "#D4B01A",
    "titleBar.activeBackground": "#E9E9E9",
    "titleBar.activeForeground": "#1E1E1E",
    "tab.activeBackground": "#F3F3F3",
    "tab.activeForeground": "#1E1E1E",
    "tab.activeBorderTop": "#A8A8A8",
    "tab.inactiveBackground": "#ECECEC",
    "tab.inactiveForeground": "#5F5F5F",
    "list.activeSelectionBackground": "#DBE8D6",
    "list.activeSelectionForeground": "#1E1E1E",
    "list.hoverBackground": "#E7EEE7",
    "breadcrumb.background": "#ECECEC",
    "breadcrumb.foreground": "#5A5A5A"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["keyword", "storage", "storage.type"],
        "settings": { "foreground": "#2E7D32" }
      },
      {
        "scope": ["string", "string.quoted"],
        "settings": { "foreground": "#A56E00" }
      },
      {
        "scope": ["variable", "variable.other"],
        "settings": { "foreground": "#333333" }
      },
      {
        "scope": ["comment"],
        "settings": { "foreground": "#7C7C7C" }
      }
    ]
  }
}
